{
  "name": "furbrief",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:stripe": "concurrently \"next dev\" \"stripe listen --forward-to localhost:3000/api/webhook\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "husky"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@stripe/stripe-js": "^9.0.1",
    "@supabase/supabase-js": "^2.0.0",
    "@tailwindcss/typography": "^0.5.9",
    "next": "14.2.5",
    "pdf-parse": "^1.1.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "stripe": "^12.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.4",
    "@types/react-dom": "^18.3.1",
    "@vitest/coverage-v8": "^4.1.3",
    "autoprefixer": "^10.4.19",
    "concurrently": "^9.2.1",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "husky": "^9.1.7",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.4",
    "vitest": "^4.1.3"
  }
}
